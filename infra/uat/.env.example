# ==========================================
# HomeTusk UAT Environment
# Copy to .env and fill in values
# ==========================================

# --- Domain ---
# Public domain or IP where the app is accessible
DOMAIN=uat.hometusk.example.com

# --- Database ---
POSTGRES_USER=hometusk
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=hometusk

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin
KEYCLOAK_FRONTEND_URL=https://${DOMAIN}

# --- Backend ---
SPRING_PROFILES_ACTIVE=local
DECISION_PROVIDER=manual
DECISION_FALLBACK_ENABLED=true

# AI Platform (optional, set if available)
# AI_PLATFORM_API_KEY=
# AI_PLATFORM_URL=http://ai-platform:8090

# ASR (optional, set if available)
# ASR_API_KEY=
# ASR_SERVICE_URL=http://asr:8000/api/v1/asr

# --- Web Client (build-time VITE_ vars) ---
# API path is relative (nginx proxies /api/v1 -> backend)
VITE_API_BASE_URL=/api/v1
VITE_AUTH_PROVIDER=keycloak
VITE_OIDC_AUTHORITY=https://${DOMAIN}/realms/hometusk
VITE_OIDC_CLIENT_ID=hometusk-web
VITE_OIDC_REDIRECT_URI=https://${DOMAIN}/callback

# --- Backend browser-facing settings ---
HOMETUSK_CORS_ALLOWED_ORIGINS=http://localhost,https://${DOMAIN}
HOMETUSK_COOKIE_SECURE=true
HOMETUSK_COOKIE_SAME_SITE=Lax
HOMETUSK_AUTH_KEYCLOAK_BASE_URL=http://keycloak:8080
HOMETUSK_AUTH_KEYCLOAK_REALM=hometusk
HOMETUSK_AUTH_KEYCLOAK_USER_CLIENT_ID=hometusk-api
HOMETUSK_AUTH_KEYCLOAK_ADMIN_CLIENT_ID=hometusk-backend
HOMETUSK_AUTH_KEYCLOAK_ADMIN_CLIENT_SECRET=hometusk-backend-secret

# --- JVM Tuning (for 8 GB VPS) ---
BACKEND_JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=60.0 -Xmx1536m -Djava.security.egd=file:/dev/./urandom
KEYCLOAK_JAVA_OPTS=-Xms512m -Xmx1024m
