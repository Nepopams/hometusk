{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hometusk.app/schemas/commands/create-task.json",
  "title": "CreateTaskPayload",
  "description": "Payload for create_task command",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Task title"
    },
    "description": {
      "type": "string",
      "maxLength": 2000,
      "description": "Task description (optional)"
    },
    "zoneId": {
      "type": "string",
      "format": "uuid",
      "description": "Zone/location ID (must exist in household)"
    },
    "assigneeId": {
      "type": "string",
      "format": "uuid",
      "description": "Assignee user ID (must be household member)"
    },
    "deadline": {
      "type": "string",
      "format": "date-time",
      "description": "Deadline in ISO 8601 format (must be in the future)"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "title": "Clean the kitchen",
      "zoneId": "123e4567-e89b-12d3-a456-426614174001",
      "deadline": "2026-01-13T18:00:00Z"
    },
    {
      "title": "Buy groceries",
      "description": "Milk, bread, eggs",
      "assigneeId": "123e4567-e89b-12d3-a456-426614174002"
    }
  ]
}
