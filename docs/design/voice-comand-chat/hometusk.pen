        },
        {
          "type": "text",
          "id": "WEEEA",
          "name": "handoffSummary",
          "fill": "$text-secondary",
          "textGrowth": "fixed-width",
          "width": "fill_container",
          "content": "Final implementation contract for the voice-to-command experience inside Commands. This frame summarizes screen coverage, component variants, responsive behavior, UX guardrails, accessibility expectations, engineering notes, and explicit non-goals.",
          "fontFamily": "Inter",
          "fontSize": 14,
          "fontWeight": "normal"
        },
        {
          "type": "frame",
          "id": "t9qPWa",
          "name": "handoffRow1",
          "width": "fill_container",
          "gap": 20,
          "children": [
            {
              "type": "frame",
              "id": "k32D7",
              "name": "QA — Screen Inventory",
              "width": "fill_container",
              "fill": "$bg-card",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "gap": 10,
              "padding": 18,
              "children": [
                {
                  "type": "text",
                  "id": "F9CfMy",
                  "name": "screenTitle",
                  "fill": "$text-primary",
                  "content": "1. Screen inventory",
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "KLc79",
                  "name": "screenBody",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Desktop: Empty; Recording; Transcribing; Draft Ready; Processing; Executed Shopping Items; Executed Task + Shopping Link; Needs Input; Rejected; ASR Permission Error; ASR Timeout / Rate Limit.\n\nTablet: Empty; Draft Ready; Executed Task + Shopping Link; Needs Input; Error State.\n\nMobile: Empty; Recording Bottom Sheet; Transcribing; Draft Ready; Processing; Executed Shopping Items; Needs Input; ASR Permission Error.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "Tn9XM",
              "name": "QA — Component Inventory",
              "width": "fill_container",
              "fill": "$bg-card",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "gap": 10,
              "padding": 18,
              "children": [
                {
                  "type": "text",
                  "id": "WFFvr",
                  "name": "componentTitle",
                  "fill": "$text-primary",
                  "content": "2. Component inventory",
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "z8ntI8",
                  "name": "componentBody",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "CommandInputBar: Idle; RecordingAvailable; ProcessingDisabled; DraftReady.\nMicButton: Default; HoverFocus; Recording; Disabled; PermissionError.\nRecordingPanel: Timer; Stop; Cancel.\nTranscriptionStatus: Uploading; Transcribing; Ready; Error.\nChatMessage: UserCommand; AssistantResponse; SystemStatusNote.\nResultCard: TaskCreated; ShoppingItemsAdded; TaskShoppingLinked; NeedsInput; Rejected.\nClarificationChips: PersonChoice; ZoneChoice; DueDateChoice; FreeTextAnswer.\nErrorBanner: MicPermissionDenied; ASRTimeout; ASRRateLimit; UnsupportedAudio.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "UAnYM",
          "name": "handoffRow2",
          "width": "fill_container",
          "gap": 20,
          "children": [
            {
              "type": "frame",
              "id": "WNtU4",
              "name": "QA — Responsive Behavior Rules",
              "width": "fill_container",
              "fill": "$bg-card",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "gap": 10,
              "padding": 18,
              "children": [
                {
                  "type": "text",
                  "id": "t7jOsf",
                  "name": "responsiveTitle",
                  "fill": "$text-primary",
                  "content": "3. Responsive behavior rules",
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "sphID",
                  "name": "responsiveBody",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Desktop: Use the existing Commands page shell. Main chat thread stays in the primary column; context/history rail is allowed only where Commands already uses that pattern. Input remains at the bottom of the main content.\n\nTablet: Prefer one readable main chat column. If history/context appears, collapse it or move it below the main content. Keep result cards at a readable max width.\n\nMobile: Full-screen Commands chat. Sticky bottom command input stays above safe area and keyboard. Recording appears as a bottom sheet or expanded bottom panel. Clarification actions stack or wrap.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "NdL2Q",
              "name": "QA — UX Rules",
              "width": "fill_container",
              "fill": "$bg-card",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "gap": 10,
              "padding": 18,
              "children": [
                {
                  "type": "text",
                  "id": "yeiwm",
                  "name": "uxTitle",
                  "fill": "$text-primary",
                  "content": "4. UX rules",
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "knIMF",
                  "name": "uxBody",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "- No auto-send after ASR.\n- Transcript appears as an editable draft.\n- User confirms manually before command execution.\n- needs_input is presented as clarification, not an error.\n- rejected is presented as a controlled outcome with a readable reason and recovery path.\n- Result cards show concrete HomeTusk domain changes, not only Done.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "H3VGw",
          "name": "handoffRow3",
          "width": "fill_container",
          "gap": 20,
          "children": [
            {
              "type": "frame",
              "id": "jDhQt",
              "name": "QA — Accessibility Notes",
              "width": "fill_container",
              "fill": "$bg-card",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "gap": 10,
              "padding": 18,
              "children": [
                {
                  "type": "text",
                  "id": "v9YWW",
                  "name": "a11yTitle",
                  "fill": "$text-primary",
                  "content": "5. Accessibility notes",
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "K7hBMb",
                  "name": "a11yBody",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Keyboard flow: input, mic, stop/cancel, send, clarification chips, retry/close, and result details must be reachable in order.\nVisible focus states: reuse existing focus variants for buttons, input, chips, and links.\nMobile touch targets: mic, send, stop, cancel, retry, close, and clarification chips must be at least 44px.\nMic permission recovery: show retry and close paths; do not trap the user.\nReadable errors: permission, timeout, rate limit, and unsupported audio copy should state what happened and what the user can do next.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "tcDng",
              "name": "QA — Engineering Handoff Notes",
              "width": "fill_container",
              "fill": "$bg-card",
              "cornerRadius": 8,
              "stroke": {
                "thickness": 1,
                "fill": "$border-subtle"
              },
              "layout": "vertical",
              "gap": 10,
              "padding": 18,
              "children": [
                {
                  "type": "text",
                  "id": "G2Qdv",
                  "name": "engTitle",
                  "fill": "$text-primary",
                  "content": "6. Engineering handoff notes",
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "XL5XJ",
                  "name": "engBody",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "- ASR call returns a transcript draft only; it does not execute a command.\n- Command send uses the existing Commands API and command lifecycle.\n- Result rendering is driven by command status plus created or updated entities: tasks, shopping list items, task-shopping links, clarification prompts, or rejection reason.\n- Preserve command history state across recording, draft editing, retry, clarification, and error recovery.\n- Do not surface AI Platform, model, schema, guardrail, or trace details as primary UI content.",
                  "lineHeight": 1.45,
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "p9jWm",
          "name": "QA — Out of Scope",
          "width": "fill_container",
          "fill": "$bg-hover-subtle",
          "cornerRadius": 8,
          "stroke": {
            "thickness": 1,
            "fill": "$border-subtle"
          },
          "layout": "vertical",
          "gap": 10,
          "padding": 18,
          "children": [
            {
              "type": "text",
              "id": "i6AeI",
              "name": "oosTitle",
              "fill": "$text-primary",
              "content": "7. Out of scope",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "W0nIXB",
              "name": "oosBody",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "TTS; wake word; streaming ASR; auto-send; generic assistant chat. This MVP remains a voice-to-command interface inside Commands, not a separate AI/chat destination.",
              "lineHeight": 1.45,
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            }
          ]
        }
      ]
    }
